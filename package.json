{
  "name": "ascensao-dos-ecos",
  "version": "0.10.0-migration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:core && npm run test:fixtures",
    "test:core": "node --import tsx --test tests/core-regression.test.ts",
    "test:fixtures": "node --import tsx --test tests/core-fixtures.test.ts",
    "test:db": "node --import tsx --test tests/db-regression.test.ts",
    "validate": "npm run prisma:generate && npm run typecheck && npm test && npm run build",
    "validate:db": "npm run db:up && npm run db:migrate && npm run test:db",
    "db:up": "docker volume create ecos_postgres_data && docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs postgres",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "@tanstack/react-query": "latest",
    "next": "latest",
    "pg": "^8.21.0",
    "react": "latest",
    "react-dom": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "prisma": "latest",
    "tsx": "^4.22.4",
    "typescript": "latest"
  }
}
