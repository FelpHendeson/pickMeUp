# Ambiente local da aplicacao.
# Valores seguros para desenvolvimento. Copie para .env apenas quando precisar.

# Opcional para jogar localmente.
# Necessario para Prisma, db:migrate, db:studio, validate:db e cloud save via API.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ascensao_dos_ecos?schema=public"

# Flag publica informativa para diferenciar ambientes na UI/configuracao futura.
NEXT_PUBLIC_APP_ENV="local"

# Flag publica reservada para controlar exibicao/uso de cloud save no futuro.
# O jogo atual continua funcionando com localStorage mesmo com cloud save desativado.
NEXT_PUBLIC_ENABLE_CLOUD_SAVE="false"
